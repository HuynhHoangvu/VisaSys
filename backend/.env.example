# ── Database ──────────────────────────────────────────────────────────────
# Local PostgreSQL (chạy docker compose hoặc cài thẳng)
DATABASE_URL="postgresql://admin:admin123@localhost:5432/crm_db"
# Trên VM Docker: DATABASE_URL="postgresql://admin:YOUR_DB_PASSWORD@postgres:5432/crm_db"

# ── Server ────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
PORT=3001
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────
SESSION_SECRET="change-this-to-a-random-string-in-production"
# Khi deploy cùng domain Nginx: SESSION_CROSS_SITE=false
# SESSION_CROSS_SITE=false

# ── AI ────────────────────────────────────────────────────────────────────
# Lấy key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
GEMINI_MODEL="gemini-3.5-flash"

# ── Redis (tuỳ chọn) ──────────────────────────────────────────────────────
# Bỏ qua nếu không có Redis — app vẫn chạy bình thường
# REDIS_URL="redis://:YOUR_REDIS_PASSWORD@localhost:6379"

# ── CORS (production) ─────────────────────────────────────────────────────
# CORS_ORIGINS="https://your-domain.com,https://192.168.100.10"
