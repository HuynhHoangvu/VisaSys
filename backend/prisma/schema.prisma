generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Column {
  id    String @id
  title String
  order Int

  tasks Task[]
}

model Task {
  id          String  @id
  content     String
  price       String
  phone       String
  email       String?
  description String?
  source      String?
  assignedTo  String

  visaType        String?
  passportNumber  String?
  maritalStatus   String?
  dependents      Int?
  priorityDate    String?
  educationLevel  String?
  englishScore    String?
  workExperience  String?
  jobType         String?    @default("Nhân viên")
  checklistType   String?    @default("tourism")
  columnId        String?
  column          Column?    @relation(fields: [columnId], references: [id])
  createdAt       DateTime   @default(now())
  documents       Json?      @default("{}")
  processingColId String     @default("proc-col-1")
  commissionPaid  Boolean    @default(false)
  recruitmentStep String?
  activities      Activity[]

  @@index([assignedTo])
  @@index([columnId])
}

model Activity {
  id        String   @id
  completed Boolean  @default(false)
  type      String
  summary   String
  assignee  String
  status    String
  fileName  String?
  fileUrl   String?
  dueText   String?
  createdAt DateTime @default(now())
  jobType   String?  @default("Nhân viên")
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Department {
  id   String @id @default(uuid())
  name String @unique

  employees            Employee[]
  departmentPermission DepartmentPermission?
  chatRoom             ChatRoom?
}

model Employee {
  id              String          @id @default(uuid())
  employeeCode    String          @unique
  email           String          @unique
  name            String
  password        String
  role            String
  baseSalary      Float           @default(6000000)
  commissionRate  Float           @default(0)
  salesRecords    SalesRecord[]
  departmentId    String?
  salaryHistories SalaryHistory[]
  leaveRequests   LeaveRequest[]
  department      Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  attendanceRecords  AttendanceRecord[]
  workspaces         Workspace[]
  permissionOverride EmployeePermissionOverride?

  createdAt DateTime @default(now())
}

model AttendanceRecord {
  id               String   @id @default(uuid())
  date             String
  inTime           String
  outTime          String
  status           String
  fine             Float    @default(0)
  halfDayDeduction Float    @default(0)
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([date])
  @@index([employeeId, date])
}

model Notification {
  id        String   @id @default(uuid())
  sender    String
  message   String
  receiver  String[]
  isRead    Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())
}

model SalesRecord {
  id       String  @id @default(uuid())
  customer String
  service  String
  profit   Float
  note     String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([createdAt])
}

model DocFolder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  files DocFile[]
}

model DocFile {
  id                 String     @id @default(uuid())
  name               String
  size               String
  fileUrl            String
  uploadedBy         String
  createdAt          DateTime   @default(now())
  cloudinaryPublicId String?
  folderId           String?
  folder             DocFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model SalaryHistory {
  id             String @id @default(uuid())
  monthYear      String
  baseSalary     Float
  totalBonus     Float
  totalDeduction Float
  finalSalary    Float

  hoaHong                 Float    @default(0)
  thuongKhac              Float    @default(0)
  tamUng                  Float    @default(0)
  manualFines             Float    @default(0)
  attendanceFines         Float    @default(0)
  halfDayDeduction        Float    @default(0)
  fullDayAbsenceDeduction Float    @default(0)
  workDays                Int      @default(0)
  workDates               String[] @default([])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([employeeId, monthYear])
  @@index([employeeId])
  @@index([monthYear])
}

model LeaveRequest {
  id          String   @id @default(uuid())
  type        String
  paidType    String   @default("Nghỉ không lương")
  startDate   String
  endDate     String
  reason      String
  status      String   @default("Chờ duyệt")
  isBulkLeave Boolean  @default(false)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([status])
  @@index([paidType])
}

model ProcessedFolder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  files ProcessedFile[]
}

model ProcessedFile {
  id                 String           @id @default(uuid())
  name               String
  size               String
  fileUrl            String
  uploadedBy         String
  createdAt          DateTime         @default(now())
  cloudinaryPublicId String?
  folderId           String?
  folder             ProcessedFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model WeeklyKPI {
  id        String   @id @default(uuid())
  weekLabel String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model Workspace {
  id         String   @id @default(uuid())
  name       String
  url        String?
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

model DepartmentPermission {
  departmentId String     @id
  permissions  String[]
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model RolePermission {
  role        String   @id
  permissions String[]
}

model EmployeePermissionOverride {
  employeeId String   @id
  granted    String[] @default([])
  revoked    String[] @default([])
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id           String        @id @default(uuid())
  name         String
  departmentId String?       @unique
  type         String        @default("department")
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(uuid())
  content    String
  senderId   String
  senderName String
  roomId     String
  createdAt  DateTime @default(now())
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([createdAt])
}

// Added for connect-pg-simple session store
model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
}
